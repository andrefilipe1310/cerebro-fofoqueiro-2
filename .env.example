# .env.example — Fofoqueiro Platform
# @path .env.example
# @responsibility Todas as variáveis de ambiente — copie para .env e preencha os valores reais
# @see docs/ENV_CONFIG.md
#
# NUNCA commitar o .env com valores reais no repositório
# Em produção: usar AWS Secrets Manager ou HashiCorp Vault (@see docs/ARCHITECTURE.md#seguranca)

# ─── BANCO DE DADOS (PostgreSQL) ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_SUPERUSER_PASSWORD=changeme

# Credenciais por serviço (criadas pelo infra/postgres/init/01_schemas_and_roles.sql)
# auth-service
AUTH_DB_USER=auth_service_user
AUTH_DB_PASSWORD=changeme_auth

# tenant-service
TENANT_DB_USER=tenant_service_user
TENANT_DB_PASSWORD=changeme_tenant

# camera-service
CAMERA_DB_USER=camera_service_user
CAMERA_DB_PASSWORD=changeme_camera

# chms-service
CHMS_DB_USER=chms_service_user
CHMS_DB_PASSWORD=changeme_chms

# recording-service
RECORDING_DB_USER=recording_service_user
RECORDING_DB_PASSWORD=changeme_recording

# alert-service
ALERT_DB_USER=alert_service_user
ALERT_DB_PASSWORD=changeme_alert

# audit-service
AUDIT_DB_USER=audit_service_user
AUDIT_DB_PASSWORD=changeme_audit

# ─── KAFKA / REDPANDA ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ─── JWT (auth-service) ───────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── CRIPTOGRAFIA (camera-service, auth-service) ─────────────────────────────
# Gerar com: openssl rand -base64 32
# NUNCA usar a mesma chave do JWT
# @see docs/ARCHITECTURE.md#camera-service (ADR-005)
ENCRYPTION_KEY=CHANGE_ME_GENERATE_DIFFERENT_FROM_JWT_SECRET

# ─── 2FA (auth-service) ───────────────────────────────────────────────────────
TOTP_ISSUER=Fofoqueiro

# ─── CLOUDFLARE R2 (recording-service, camera-service) ───────────────────────
# Configuração de desenvolvimento (MinIO local como substituto):
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=fofoqueiro-dev
R2_PUBLIC_URL=http://localhost:9000/fofoqueiro-dev
R2_ENDPOINT=http://localhost:9000

# Para produção (Cloudflare R2):
# R2_ACCOUNT_ID=CHANGE_ME_cloudflare_account_id
# R2_ACCESS_KEY_ID=CHANGE_ME
# R2_SECRET_ACCESS_KEY=CHANGE_ME
# R2_BUCKET_NAME=fofoqueiro-recordings
# R2_PUBLIC_URL=https://pub-CHANGE_ME.r2.dev
# R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com

# ─── MEDIAMTX (camera-service, chms-service) ─────────────────────────────────
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_AUTH_TOKEN=changeme_mediamtx_secret
MEDIAMTX_PUBLIC_URL=http://localhost:8889

# ─── INTERNAL (camera-service) ───────────────────────────────────────────────
# Segredo para autenticar webhook do MediaMTX no backend
INTERNAL_API_SECRET=changeme_internal_secret

# ─── E-MAIL (notification-service) ──────────────────────────────────────────
# Em desenvolvimento: Mailhog é usado por padrão (sem credenciais necessárias).
#   Acesse http://localhost:8025 para ver os e-mails enviados.
# Em produção: preencha com credenciais reais do SendGrid.
#   Gere a API key em: https://app.sendgrid.com/settings/api_keys
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.CHANGE_ME_paste_your_sendgrid_api_key_here
EMAIL_FROM=noreply@fofoqueiro.com
EMAIL_FROM_NAME=Fofoqueiro

# ─── APLICAÇÃO ────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── FRONTEND (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MEDIA_URL=http://localhost:8889
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
